# CV Analyzer Service Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENV=development

# Logging
LOG_LEVEL=INFO

# File Upload
MAX_FILE_SIZE=10485760

# API
API_TITLE=CV Analyzer Service
API_VERSION=1.0.0

# Laravel App URL (used to fetch skills from the database)
# Laragon virtual host — the folder name becomes the domain: SmarttelErpSystem.test
# The Python service calls: {LARAVEL_APP_URL}/api/hr/cv-analyzer/skills
LARAVEL_APP_URL=http://SmarttelErpSystem.test

# How long (seconds) to cache the skills fetched from the DB (default: 300 = 5 min)
SKILLS_CACHE_TTL=300

# Timeout (seconds) for requests to the Laravel API
LARAVEL_REQUEST_TIMEOUT=10
